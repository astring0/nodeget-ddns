# Worker env — paste into NodeGet js-worker `env` JSON field.
# Worker reads these via the `env` arg of onRoute/onCron — NOT process.env.
# Values can be primitives (string/number/bool) or any JSON (arrays/objects).

# =============== Required (global) ===============

# Cloudflare API Token (Zone -> DNS -> Edit, scoped to the target zone(s) only).
# https://dash.cloudflare.com/profile/api-tokens
CF_API_TOKEN=cf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NodeGet platform API token — used by EVERY globalThis.nodeget(...) RPC call inside
# the worker (task_create_task_blocking / kv_* / crontab-result_query / ...).
# Without this token, RPC calls return silently empty.
# Get it from the NodeGet dashboard's API-token section.
# (Legacy alias: `token` — also accepted, matches NodeGet's built-in worker convention.)
NODEGET_API_TOKEN=ng-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OPTIONAL — only needed if you want to expose the HTTP onRoute entry (sh-agent
# push / curl manual trigger / NodeGet agent http_request task).
# Pure blocking-task or cron-pull deployments DON'T need this — leave unset and
# onRoute will return 503 http_route_disabled, while onCall/onCron/onInlineCall
# continue to work normally.
# If you do set it: `openssl rand -hex 32`.
# SHARED_SECRET=replace-with-a-strong-random-string

# Default Cloudflare Zone ID. Per-mapping zone_id overrides this.
CF_ZONE_ID=0123456789abcdef0123456789abcdef

# Optional: default TTL / proxy for all mappings (each mapping can override).
CF_RECORD_TTL=60
CF_RECORD_PROXIED=false

# =============== Mappings ===============
# One entry per (agent + record) pair. Each gets its own KV namespace so they
# don't interfere.
#
# IP source — each mapping picks ONE of:
#   - `agent_uuid` (recommended): worker calls task_create_task_blocking() each tick
#     to dispatch the ip task directly to the agent and get the result synchronously.
#     No agent cron needed.
#   - `cron_name_fetch_ip` (fallback): worker reads the latest crontab_result for a
#     pre-registered agent cron. Needs the agent cron to exist separately.
#
# Where to put MAPPINGS:
#   1. HERE in env (stable config)                                      — recommended default
#   2. In each server cron's params.mappings (per-cron, replaces env)   — multi-tenant / A/B
#   3. Both: env as fallback, params overrides for specific crons       — also valid
# Either way, CF_API_TOKEN and SHARED_SECRET STAY IN ENV — never embed in cron params.
#
# NodeGet env accepts JSON arrays/objects directly (no need to stringify).
# Example (2 mappings: home router IPv4+IPv6, off-site NAS IPv4 only):
MAPPINGS=[
  {
    "name": "home",
    "agent_uuid": "00000000-0000-0000-0000-aaaaaaaaaaaa",
    "record_v4": "home.example.com",
    "record_v6": "home.example.com",
    "family": "both"
  },
  {
    "name": "nas",
    "agent_uuid": "00000000-0000-0000-0000-bbbbbbbbbbbb",
    "record_v4": "nas.example.com",
    "family": "v4"
  }
]

# Optional per-mapping fields you can add inside each object:
#   "ip_task_timeout_ms": 10000      # blocking task wait, default 10000ms
#   "cron_name_fetch_ip": "..."      # fallback if blocking task fails
#   "zone_id":            "..."      # cross-zone — overrides CF_ZONE_ID
#   "record_id_v4":       "..."      # skip lookup_by_name + KV cache
#   "record_id_v6":       "..."
#   "ttl":                60
#   "proxied":            false

# Default blocking-task timeout for all mappings (each can override).
IP_TASK_TIMEOUT_MS=10000

# =============== Behavior ===============

# Stale threshold for forced re-push, in hours. 0 = disabled.
# Defends against silent CF dashboard edits.
HEARTBEAT_HOURS=24

# Push-mode only: when set, accepts NG-Connecting-IP as the source IP.
# Auto-disabled if any mapping has cron_name_fetch_ip set (pull is unambiguous).
# WARNING per NodeGet docs: may be 127.0.0.1 behind a reverse proxy.
TRUST_PEER_IP_HEADER=true

# =============== Legacy single-mapping shortcut ===============
# If MAPPINGS is unset, the worker builds a one-entry "default" mapping from
# these flat fields. Convenient for the simplest "one home, one record" setup.
#
# AGENT_UUID=00000000-0000-0000-0000-aaaaaaaaaaaa
# RECORD_FAMILY=v4                       # v4 | v6 | both
# CF_RECORD_NAME=home.example.com        # shared default for v4/v6
# CF_RECORD_NAME_V4=                     # overrides CF_RECORD_NAME for A
# CF_RECORD_NAME_V6=                     # overrides CF_RECORD_NAME for AAAA
# CF_RECORD_ID_V4=
# CF_RECORD_ID_V6=
# CRON_NAME_FETCH_IP=                    # fallback only — leave empty when using AGENT_UUID
