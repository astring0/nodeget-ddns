# Worker env — paste into NodeGet js-worker `env` JSON field.
# Worker reads these via the `env` arg of onCron(params, env, ctx) — NOT process.env.
# NodeGet env accepts any JSON value (string / number / bool / array / object) directly.

# ============ Required ============

# Cloudflare API Token (Zone -> DNS -> Edit, scoped to the target zone(s) only).
# https://dash.cloudflare.com/profile/api-tokens
CF_API_TOKEN=cf-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NodeGet platform API token — injected into every globalThis.nodeget(...) RPC call.
# Get it from the NodeGet dashboard's API-token section.
NODEGET_API_TOKEN=ng-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default Cloudflare Zone ID. Per-mapping `zone_id` overrides this.
CF_ZONE_ID=0123456789abcdef0123456789abcdef

# ============ Optional ============

# Default values used by every mapping (each mapping can override).
CF_RECORD_TTL=60
CF_RECORD_PROXIED=false

# Blocking task wait (ms). Each mapping can override via ip_task_timeout_ms.
IP_TASK_TIMEOUT_MS=10000

# Force re-push every N hours even if KV says IP unchanged.
# Defends against silent edits on the Cloudflare dashboard. 0 = disabled.
HEARTBEAT_HOURS=24

# ============ MAPPINGS ============
# MAPPINGS array — list of (agent + record) bindings to sync each tick.
#
# Recommended: pass mappings in the cron params instead of here. See cron.example.json.
# But you can also pin them in env if you don't want them to live in cron history.
#
# MAPPINGS=[
#   {
#     "name": "home",
#     "agent_uuid": "00000000-0000-0000-0000-aaaaaaaaaaaa",
#     "record_v4": "home.example.com",
#     "family": "v4"
#   }
# ]

# Mapping object fields:
#   name              — KV namespace key (any unique string)            [required]
#   agent_uuid        — NodeGet agent to dispatch the ip task to        [required]
#   record_v4         — required if family ∈ {v4, both}
#   record_v6         — required if family ∈ {v6, both}
#   family            — "v4" (default) | "v6" | "both"
#   zone_id           — overrides env.CF_ZONE_ID for this mapping
#   record_id_v4      — skip lookup_by_name + KV cache (when set)
#   record_id_v6
#   ttl               — overrides env.CF_RECORD_TTL
#   proxied           — overrides env.CF_RECORD_PROXIED
#   ip_task_timeout_ms — overrides env.IP_TASK_TIMEOUT_MS

# ============ Legacy single-mapping shortcut ============
# If MAPPINGS is not set in env AND cron params doesn't carry mappings,
# the worker builds a one-entry "default" mapping from these flat fields.
# Convenient for the simplest one-home/one-record setup.
#
# AGENT_UUID=00000000-0000-0000-0000-aaaaaaaaaaaa
# CF_RECORD_NAME=home.example.com
# RECORD_FAMILY=v4
